# LINE configuration (canonical names)
LINE_CHANNEL_ACCESS_TOKEN=replace-with-your-line-channel-access-token
LINE_TO_GROUP_ID=replace-with-your-line-group-id

# LINE configuration aliases (optional alternative to canonical names)
# CHANNEL_ACCESS_TOKEN=replace-with-your-line-channel-access-token
# TARGET_GROUP_ID=replace-with-your-line-group-id

# Runtime policy defaults (align with EDD/PDD)
APP_TIMEZONE=Asia/Taipei
POLL_INTERVAL_SEC=60
COOLDOWN_SEC=300
STALE_THRESHOLD_SEC=90
MAX_RETRY_COUNT=3
VALUATION_RUN_TIME=14:00
